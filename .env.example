# Database Connection (Used by Drizzle)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres

# Supabase API URL
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-ID].supabase.co"

# Supabase Public/Anon Key (Used by the Auth helpers)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="[YOUR-ANON-KEY]"

# Supabase Service Role Key (Used for Admin tasks)
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"

# Google OAuth Credentials (REQUIRED for Token Refresh)
# Must match the credentials used in Supabase Auth -> Google Provider
GOOGLE_CLIENT_ID="[YOUR-GOOGLE-CLIENT-ID]"
GOOGLE_CLIENT_SECRET="[YOUR-GOOGLE-CLIENT-SECRET]"

# Application URL (REQUIRED for OAuth Redirects)
# Set to your production URL on deployment platforms (e.g., https://jnaninyoga.up.railway.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
